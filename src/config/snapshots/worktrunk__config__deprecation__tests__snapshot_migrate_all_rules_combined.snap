---
source: src/config/deprecation.rs
expression: "migration_diff(content, &migrated)"
---
-worktree-path = "../{{ repo_root }}.{{ branch }}"
-pre-create = "npm install"
+worktree-path = "../{{ repo_path }}.{{ branch }}"
+pre-start = "npm install"
 
-[pre-merge]
+[[pre-merge]]
 test = "cargo test"
+
+[[pre-merge]]
 lint = "cargo clippy"
 
-[commit-generation]
-command = "llm"
-args = ["-m", "haiku"]
+[commit.generation]
+command = "llm -m haiku"
 
-[ci]
+[forge]
 platform = "github"
 
-[select]
+[switch.picker]
 pager = "delta"
-timeout-ms = 500
 
 [merge]
-no-ff = true
+ff = false
 
 [switch]
-no-cd = true
+cd = false
 
-[post-create]
+[post-start]
 server = "npm run dev"
-
-[projects."github.com/user/repo"]
-approved-commands = ["npm test"]
